{
  "name": "agent-base",
  "version": "0.1.0",
  "type": "module",
  "description": "Standard base scaffolding for agent projects. See AGENT_STANDARDS.md.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "start": "node --env-file=.env dist/main.js",
    "build": "tsc",
    "tsgo": "tsc --noEmit",
    "check": "pnpm format && pnpm lint",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "node --env-file=.env --import tsx/esm src/main.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.39.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}